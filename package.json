{
  "name": "kiracode-workspace",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:backend": "KIRACODE_PORT=3141 npm run dev -w kiracode",
    "dev:frontend": "VITE_KIRACODE_API_URL=http://127.0.0.1:3141/trpc npm run dev -w @kiracode/frontend",
    "dev:full": "concurrently -k -n backend,frontend -c blue,magenta \"npm run dev:backend\" \"npm run dev:frontend\"",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint apps packages",
    "lint:fix": "oxlint --fix apps packages",
    "format": "oxfmt --check apps packages",
    "format:fix": "oxfmt apps packages"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "turbo": "^2.5.8",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
