{
  "name": "kiracode-workspace",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=kiracode --filter=@kiracode/frontend",
    "dev:backend": "turbo run dev --filter=kiracode",
    "dev:frontend": "turbo run dev --filter=@kiracode/frontend",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint apps packages",
    "lint:fix": "oxlint --fix apps packages",
    "format": "oxfmt --check apps packages",
    "format:fix": "oxfmt apps packages"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "turbo": "^2.8.20",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
